# ── Telegram ──────────────────────────────────────────
# Obtén este token hablando con @BotFather en Telegram
TELEGRAM_TOKEN=tu_token_aqui

# ── OpenAI (para transcripción de audios) ─────────────
# Obtén tu key en: https://platform.openai.com/api-keys
# Si no tienes, los audios no se transcribirán (todo lo demás sí funciona)
OPENAI_API_KEY=tu_key_aqui

# ── Seguridad ──────────────────────────────────────────
# Cadena aleatoria larga para firmar los tokens de sesión
# Puedes generar una en: https://randomkeygen.com
SECRET_KEY=cambia_esto_por_una_clave_secreta_larga

# ── Base de datos ──────────────────────────────────────
# En Railway esto se configura automáticamente.
# Para desarrollo local se usa SQLite (no necesitas cambiar esto).
DATABASE_URL=sqlite+aiosqlite:///./recordatorio.db

# ── App ────────────────────────────────────────────────
PORT=8080
